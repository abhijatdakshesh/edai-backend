# ── Identity Service — Environment Variables ─────────────────────────────────
# Copy to .env and fill in real values before running.

PORT=3001

# JWT — generate a random 64-char secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# PostgreSQL (Phase 2 — not required for in-memory dev mode)
DATABASE_URL=postgresql://edai:edai@localhost:5432/identity_db

# Redis (Phase 2 — refresh token store)
REDIS_URL=redis://localhost:6379

# Keycloak OIDC (Phase 3 — SSO integration)
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=edai
KEYCLOAK_CLIENT_ID=edai-backend
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
